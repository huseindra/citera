# Copy to .env and fill in. Development values only.
DATABASE_URL=postgresql+asyncpg://citera:citera@localhost:5433/citera
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
EMBEDDING_DIM=1024
# ALWAYS explicit — no automatic provider selection. Startup fails fast
# when the configured provider is unavailable.
# Providers: ollama | tei | openai | jina | openai-compat | voyage | fake
EMBEDDING_PROVIDER=fake
# Provider and model are separate concerns (e.g. bge-m3 via ollama):
EMBEDDING_MODEL=
# Optional: override the provider's preset base URL / API key
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# auto | claude | scripted — auto picks claude when ANTHROPIC_API_KEY is set
LLM_PROVIDER=auto
CLAUDE_MODEL=claude-sonnet-5
