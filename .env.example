# Copy to .env and fill in. Development values only.
DATABASE_URL=postgresql+asyncpg://citera:citera@localhost:5433/citera
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
EMBEDDING_DIM=1024
# auto | voyage | fake — auto picks voyage when VOYAGE_API_KEY is set
EMBEDDINGS_PROVIDER=auto
# auto | claude | scripted — auto picks claude when ANTHROPIC_API_KEY is set
LLM_PROVIDER=auto
CLAUDE_MODEL=claude-sonnet-5
